+static double ao_visualization_sample_to_double(int format, const void *data,
+                                                int index)
+{
+    switch (format) {
+    case AF_FORMAT_U8:
+        return (((const uint8_t *)data)[index] - 128.0) / 128.0;
+    case AF_FORMAT_S16:
+        return ((const int16_t *)data)[index] / 32768.0;
+    case AF_FORMAT_S32:
+        return ((const int32_t *)data)[index] / 2147483648.0;
+    case AF_FORMAT_FLOAT:
+        return MPCLAMP(((const float *)data)[index], -1.0, 1.0);
+    case AF_FORMAT_DOUBLE:
+        return MPCLAMP(((const double *)data)[index], -1.0, 1.0);
+    default:
+        return 0.0;
+    }
+}
