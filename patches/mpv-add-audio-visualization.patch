+static void lock_core(mpv_handle *ctx);
+static void unlock_core(mpv_handle *ctx);
+
+MPV_EXPORT int mpv_audio_visualization_configure(
+    mpv_handle *ctx, int mode, int channel_mode, int band_count,
+    int pcm_window_size, int fft_size, int hop_size, int raw_chunk_size,
+    int max_fps)
+{
+    if (!ctx)
+        return MPV_ERROR_INVALID_PARAMETER;
+
+    switch (mode) {
+    case MPV_AUDIO_VISUALIZATION_MODE_BANDS:
+    case MPV_AUDIO_VISUALIZATION_MODE_PCM_WINDOW:
+    case MPV_AUDIO_VISUALIZATION_MODE_HYBRID:
+    case MPV_AUDIO_VISUALIZATION_MODE_RAW_PCM:
+        break;
+    default:
+        return MPV_ERROR_INVALID_PARAMETER;
+    }
+
+    switch (channel_mode) {
+    case MPV_AUDIO_VISUALIZATION_CHANNEL_MODE_MONO:
+    case MPV_AUDIO_VISUALIZATION_CHANNEL_MODE_STEREO:
+        break;
+    default:
+        return MPV_ERROR_INVALID_PARAMETER;
+    }
+
+    int result = MPV_ERROR_PROPERTY_UNAVAILABLE;
+    lock_core(ctx);
+    if (ctx->mpctx->ao) {
+        result = ao_configure_visualization(
+            ctx->mpctx->ao, mode, channel_mode, band_count, pcm_window_size,
+            fft_size, hop_size, raw_chunk_size, max_fps);
+    }
+    unlock_core(ctx);
+
+    return result;
+}
+
+MPV_EXPORT int mpv_audio_visualization_read(
+    mpv_handle *ctx, int max_bands, int max_pcm, int *version, int *mode,
+    int *channel_mode, uint64_t *seq, double *pts_seconds, double *peak,
+    double *rms, int *sample_rate, int *channels, int *frames_per_channel,
+    double *bands, double *pcm)
+{
+    if (!ctx || max_bands < 0 || max_pcm < 0)
+        return MPV_ERROR_INVALID_PARAMETER;
+
+    int result = MPV_ERROR_PROPERTY_UNAVAILABLE;
+    lock_core(ctx);
+    if (ctx->mpctx->ao) {
+        if (version)
+            *version = AO_VISUALIZATION_VERSION;
+        result = ao_read_visualization(ctx->mpctx->ao, mode, channel_mode, peak,
+                                       rms, bands, max_bands, pcm, max_pcm,
+                                       sample_rate, channels, frames_per_channel,
+                                       seq);
+        if (pts_seconds) {
+            double pts = playing_audio_pts(ctx->mpctx);
+            *pts_seconds = pts == MP_NOPTS_VALUE ? NAN : pts;
+        }
+    }
+    unlock_core(ctx);
+
+    return result;
 }
 
