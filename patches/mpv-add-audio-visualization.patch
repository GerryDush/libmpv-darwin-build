+static void ao_visualization_calculate_levels(const float *samples,
+                                              int sample_count, double *peak,
+                                              double *rms)
+{
+    double peak_value = 0.0;
+    double rms_sum = 0.0;
+
+    if (sample_count <= 0) {
+        if (peak)
+            *peak = 0.0;
+        if (rms)
+            *rms = 0.0;
+        return;
+    }
+
+    for (int n = 0; n < sample_count; n++) {
+        double value = samples[n];
+        double abs_value = fabs(value);
+        peak_value = MPMAX(peak_value, abs_value);
+        rms_sum += value * value;
+    }
+
+    if (peak)
+        *peak = MPCLAMP(peak_value, 0.0, 1.0);
+    if (rms)
+        *rms = MPCLAMP(sqrt(rms_sum / sample_count), 0.0, 1.0);
+}
+
+static void ao_visualization_calculate_bands(struct ao *ao,
+                                             const float *samples,
+                                             int sample_count, int band_count,
+                                             double *bands_out)
+{
+    if (sample_count <= 0 || ao->samplerate <= 0 || band_count <= 0) {
+        if (band_count > 0)
+            memset(bands_out, 0, sizeof(double) * band_count);
+        return;
+    }
+
+    float windowed[AO_VISUALIZATION_MAX_WINDOW_SIZE];
+    double min_freq = 40.0;
+    double max_freq = MPMIN(16000.0, ao->samplerate * 0.45);
+    double scales[AO_VISUALIZATION_MAX_BANDS];
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    memcpy(scales, ao->visualization_band_scales, sizeof(double) * band_count);
+    pthread_mutex_unlock(&ao->visualization_lock);
+
+    for (int n = 0; n < sample_count; n++) {
+        double weight = sample_count > 1
+                            ? 0.5 - 0.5 * cos((2.0 * M_PI * n) / (sample_count - 1))
+                            : 1.0;
+        windowed[n] = samples[n] * weight;
+    }
+
+    for (int band = 0; band < band_count; band++) {
+        double frac = band_count > 1 ? (double)band / (band_count - 1) : 0.0;
+        double freq = min_freq * pow(max_freq / min_freq, frac);
+        double omega = 2.0 * M_PI * freq / ao->samplerate;
+        double coeff = 2.0 * cos(omega);
+        double s_prev = 0.0;
+        double s_prev2 = 0.0;
+
+        for (int n = 0; n < sample_count; n++) {
+            double s = windowed[n] + coeff * s_prev - s_prev2;
+            s_prev2 = s_prev;
+            s_prev = s;
+        }
+
+        double power =
+            s_prev2 * s_prev2 + s_prev * s_prev - coeff * s_prev * s_prev2;
+        double magnitude = sqrt(MPMAX(power, 0.0)) / sample_count;
+        double scale = scales[band];
+
+        if (magnitude > scale) {
+            scale = magnitude;
+        } else {
+            scale = scale * 0.992 + magnitude * 0.008;
+        }
+
+        scale = MPMAX(scale, 1e-6);
+        scales[band] = scale;
+        bands_out[band] = MPCLAMP(sqrt(MPMIN(magnitude / scale, 1.0)), 0.0, 1.0);
+    }
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    memcpy(ao->visualization_band_scales, scales, sizeof(double) * band_count);
+    pthread_mutex_unlock(&ao->visualization_lock);
+}
+
+int ao_configure_visualization(struct ao *ao, int mode, int channel_mode,
+                               int band_count, int pcm_window_size,
+                               int fft_size, int hop_size,
+                               int raw_chunk_size, int max_fps)
+{
+    if (!ao)
+        return -1;
+
+    int clamped_mode = MPCLAMP(mode, AO_VISUALIZATION_MODE_BANDS,
+                               AO_VISUALIZATION_MODE_RAW_PCM);
+    int clamped_channel_mode = MPCLAMP(channel_mode,
+                                       AO_VISUALIZATION_CHANNEL_MODE_MONO,
+                                       AO_VISUALIZATION_CHANNEL_MODE_STEREO);
+    int clamped_fft_size =
+        ao_visualization_clamp(fft_size, AO_VISUALIZATION_DEFAULT_FFT_SIZE,
+                               64, AO_VISUALIZATION_MAX_WINDOW_SIZE);
+    int clamped_band_count =
+        ao_visualization_clamp(band_count,
+                               AO_VISUALIZATION_DEFAULT_BAND_COUNT, 1,
+                               AO_VISUALIZATION_MAX_BANDS);
+    int clamped_pcm_window_size =
+        ao_visualization_clamp(pcm_window_size,
+                               AO_VISUALIZATION_DEFAULT_PCM_WINDOW_SIZE, 32,
+                               AO_VISUALIZATION_MAX_PCM_FRAMES);
+    int clamped_raw_chunk_size =
+        ao_visualization_clamp(raw_chunk_size,
+                               AO_VISUALIZATION_DEFAULT_RAW_CHUNK_SIZE, 32,
+                               AO_VISUALIZATION_MAX_PCM_FRAMES);
+    int clamped_hop_size =
+        ao_visualization_clamp(hop_size, AO_VISUALIZATION_DEFAULT_HOP_SIZE, 1,
+                               clamped_fft_size);
+    int clamped_max_fps =
+        max_fps < 0 ? AO_VISUALIZATION_DEFAULT_MAX_FPS
+                    : MPCLAMP(max_fps, 0, 240);
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    ao->visualization_mode = clamped_mode;
+    ao->visualization_channel_mode = clamped_channel_mode;
+    ao->visualization_band_count = clamped_band_count;
+    ao->visualization_pcm_window_size = clamped_pcm_window_size;
+    ao->visualization_fft_size = clamped_fft_size;
+    ao->visualization_hop_size = clamped_hop_size;
+    ao->visualization_raw_chunk_size = clamped_raw_chunk_size;
+    ao->visualization_max_fps = clamped_max_fps;
+    ao->visualization_pcm_channels =
+        clamped_channel_mode == AO_VISUALIZATION_CHANNEL_MODE_STEREO ? 2 : 1;
+    ao_visualization_clear_buffers(ao);
+    pthread_mutex_unlock(&ao->visualization_lock);
+
+    return 0;
+}
+
+static void ao_visualization_process_data(struct ao *ao, void **data,
+                                          int num_samples)
+{
+    int input_channels = ao->channels.num;
+    if (input_channels <= 0 || num_samples <= 0)
+        return;
 
+    int format = af_fmt_from_planar(ao->format);
+    switch (format) {
+    case AF_FORMAT_U8:
+    case AF_FORMAT_S16:
+    case AF_FORMAT_S32:
+    case AF_FORMAT_FLOAT:
+    case AF_FORMAT_DOUBLE:
+        break;
+    default:
+        return;
+    }
+
+    bool planar = af_fmt_is_planar(ao->format);
+    float analysis_samples[AO_VISUALIZATION_MAX_WINDOW_SIZE];
+    float pcm_samples[AO_VISUALIZATION_MAX_PCM_FRAMES *
+                      AO_VISUALIZATION_MAX_PCM_CHANNELS];
+    double band_values[AO_VISUALIZATION_MAX_BANDS] = {0};
+    double peak = 0.0;
+    double rms = 0.0;
+    int mode = AO_VISUALIZATION_MODE_HYBRID;
+    int channel_mode = AO_VISUALIZATION_CHANNEL_MODE_MONO;
+    int band_count = 0;
+    int analysis_frames = 0;
+    int pcm_frames = 0;
+    int pcm_channels = 1;
+    int required_frames = 0;
+    int step_frames = 1;
+    bool emit_bands = false;
+    bool emit_pcm = false;
+    bool should_emit = false;
+    double now = mp_time_sec();
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    for (int sample = 0; sample < num_samples; sample++) {
+        double mixed = 0.0;
+        double left = 0.0;
+        double right = 0.0;
+        for (int channel = 0; channel < input_channels; channel++) {
+            const void *plane = planar ? data[channel] : data[0];
+            int index = planar ? sample : sample * input_channels + channel;
+            double value =
+                ao_visualization_sample_to_double(format, plane, index);
+            if (channel == 0)
+                left = value;
+            if (channel == 1)
+                right = value;
+            mixed += value;
+        }
+        mixed /= input_channels;
+        if (input_channels == 1)
+            right = left;
+
+        ao->visualization_window[ao->visualization_window_pos] = mixed;
+        ao->visualization_window_stereo
+            [ao->visualization_window_pos * AO_VISUALIZATION_MAX_PCM_CHANNELS] =
+                left;
+        ao->visualization_window_stereo
+            [ao->visualization_window_pos * AO_VISUALIZATION_MAX_PCM_CHANNELS + 1] =
+                right;
+        ao->visualization_window_pos =
+            (ao->visualization_window_pos + 1) % AO_VISUALIZATION_MAX_WINDOW_SIZE;
+        if (ao->visualization_window_fill < AO_VISUALIZATION_MAX_WINDOW_SIZE)
+            ao->visualization_window_fill++;
+        ao->visualization_pending_frames++;
+    }
+
+    mode = ao->visualization_mode;
+    channel_mode = ao->visualization_channel_mode;
+    band_count = ao->visualization_band_count;
+    emit_bands = mode == AO_VISUALIZATION_MODE_BANDS ||
+                 mode == AO_VISUALIZATION_MODE_HYBRID;
+    emit_pcm = mode == AO_VISUALIZATION_MODE_PCM_WINDOW ||
+               mode == AO_VISUALIZATION_MODE_HYBRID ||
+               mode == AO_VISUALIZATION_MODE_RAW_PCM;
+    analysis_frames = emit_bands ? ao->visualization_fft_size
+                                 : mode == AO_VISUALIZATION_MODE_RAW_PCM
+                                       ? ao->visualization_raw_chunk_size
+                                       : ao->visualization_pcm_window_size;
+    pcm_frames = emit_pcm ? (mode == AO_VISUALIZATION_MODE_RAW_PCM
+                                 ? ao->visualization_raw_chunk_size
+                                 : ao->visualization_pcm_window_size)
+                          : 0;
+    pcm_channels = channel_mode == AO_VISUALIZATION_CHANNEL_MODE_STEREO ? 2 : 1;
+    required_frames = emit_bands ? ao->visualization_fft_size : pcm_frames;
+    if (emit_pcm)
+        required_frames = MPMAX(required_frames, pcm_frames);
+    step_frames = mode == AO_VISUALIZATION_MODE_RAW_PCM
+                      ? ao->visualization_raw_chunk_size
+                      : ao->visualization_hop_size;
+    step_frames = MPMAX(step_frames, 1);
+
+    double min_interval = ao->visualization_max_fps > 0
+                              ? 1.0 / ao->visualization_max_fps
+                              : 0.0;
+    bool interval_ready = min_interval <= 0.0 ||
+                          now - ao->visualization_last_emit_time >= min_interval;
+
+    if (required_frames > 0 &&
+        ao->visualization_window_fill >= required_frames &&
+        ao->visualization_pending_frames >= step_frames && interval_ready)
+    {
+        if (analysis_frames > 0) {
+            int start = (ao->visualization_window_pos - analysis_frames +
+                         AO_VISUALIZATION_MAX_WINDOW_SIZE) %
+                        AO_VISUALIZATION_MAX_WINDOW_SIZE;
+            for (int n = 0; n < analysis_frames; n++) {
+                int src = (start + n) % AO_VISUALIZATION_MAX_WINDOW_SIZE;
+                analysis_samples[n] = ao->visualization_window[src];
+            }
+        }
+
+        if (emit_pcm && pcm_frames > 0) {
+            int start = (ao->visualization_window_pos - pcm_frames +
+                         AO_VISUALIZATION_MAX_WINDOW_SIZE) %
+                        AO_VISUALIZATION_MAX_WINDOW_SIZE;
+            for (int n = 0; n < pcm_frames; n++) {
+                int src = (start + n) % AO_VISUALIZATION_MAX_WINDOW_SIZE;
+                if (pcm_channels == 1) {
+                    pcm_samples[n] = ao->visualization_window[src];
+                } else {
+                    pcm_samples[n * 2] = ao->visualization_window_stereo
+                        [src * AO_VISUALIZATION_MAX_PCM_CHANNELS];
+                    pcm_samples[n * 2 + 1] = ao->visualization_window_stereo
+                        [src * AO_VISUALIZATION_MAX_PCM_CHANNELS + 1];
+                }
+            }
+        }
+
+        ao->visualization_pending_frames %= step_frames;
+        ao->visualization_last_emit_time = now;
+        should_emit = true;
+    }
+    pthread_mutex_unlock(&ao->visualization_lock);
+
+    if (!should_emit)
+        return;
+
+    ao_visualization_calculate_levels(analysis_samples, analysis_frames,
+                                      &peak, &rms);
+    if (emit_bands && band_count > 0) {
+        ao_visualization_calculate_bands(ao, analysis_samples, analysis_frames,
+                                         band_count, band_values);
+    }
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    ao->visualization_peak = peak;
+    ao->visualization_rms = rms;
+    ao->visualization_pcm_frames = emit_pcm ? pcm_frames : 0;
+    ao->visualization_pcm_channels = pcm_channels;
+    if (emit_bands) {
+        memcpy(ao->visualization_bands, band_values,
+               sizeof(double) * band_count);
+    } else {
+        memset(ao->visualization_bands, 0, sizeof(ao->visualization_bands));
+    }
+    if (emit_pcm) {
+        int pcm_values = pcm_frames * pcm_channels;
+        for (int n = 0; n < pcm_values; n++)
+            ao->visualization_pcm[n] = MPCLAMP(pcm_samples[n], -1.0, 1.0);
+    } else {
+        memset(ao->visualization_pcm, 0, sizeof(ao->visualization_pcm));
+    }
+    ao->visualization_seq += 1;
+    pthread_mutex_unlock(&ao->visualization_lock);
+
+    ao_visualization_notify(ao);
+}
+
+int ao_read_visualization(struct ao *ao, int *mode, int *channel_mode,
+                          double *peak, double *rms, double *bands,
+                          int max_bands, double *pcm, int max_pcm,
+                          int *sample_rate, int *channels,
+                          int *frames_per_channel, uint64_t *seq)
+{
+    if (!ao)
+        return 0;
+
+    pthread_mutex_lock(&ao->visualization_lock);
+    bool has_bands = ao->visualization_mode == AO_VISUALIZATION_MODE_BANDS ||
+                     ao->visualization_mode == AO_VISUALIZATION_MODE_HYBRID;
+    int band_count = has_bands ? ao->visualization_band_count : 0;
+    int clamped_bands = MPMIN(max_bands, band_count);
+    int pcm_values = MPMIN(max_pcm, ao->visualization_pcm_frames *
+                                    ao->visualization_pcm_channels);
+    if (mode)
+        *mode = ao->visualization_mode;
+    if (channel_mode)
+        *channel_mode = ao->visualization_channel_mode;
+    if (peak)
+        *peak = MPCLAMP(ao->visualization_peak, 0.0, 1.0);
+    if (rms)
+        *rms = MPCLAMP(ao->visualization_rms, 0.0, 1.0);
+    if (bands && clamped_bands > 0)
+        memcpy(bands, ao->visualization_bands, sizeof(double) * clamped_bands);
+    if (pcm && pcm_values > 0)
+        memcpy(pcm, ao->visualization_pcm, sizeof(double) * pcm_values);
+    if (sample_rate)
+        *sample_rate = ao->samplerate;
+    if (channels)
+        *channels = ao->visualization_pcm_channels;
+    if (frames_per_channel)
+        *frames_per_channel = ao->visualization_pcm_frames;
+    if (seq)
+        *seq = ao->visualization_seq;
+    pthread_mutex_unlock(&ao->visualization_lock);
+
+    return clamped_bands;
+}
